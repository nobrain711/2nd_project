# =========================================================================
# Project:
# - CCRM
#
# File: .env.example
#
# Purpose:
# - 개발(dev) / 전체(full) 실행 환경 변수 템플릿
# - 실제 값은 .env.dev 또는 .env.full 로 복사해서 사용
#
# Author: @nobrain711
# Created: 2026-03-12
# =========================================================================


# ========================================================================
# Python
# ========================================================================

PYTHONPATH=/app/notebooks



# ========================================================================
# PIPELINE API
# ========================================================================

# DEV (ngrok 외부 접속)
PIPELINE_API=https://ccrm-pipeline.ngrok-free.app

# FULL (docker internal network)
# PIPELINE_API=http://pipeline:8000



# ========================================================================
# MLFLOW
# ========================================================================

# DEV (외부 접근)
MLFLOW_API=https://ccrm-mlflow.ngrok-free.app

# FULL (docker 내부 통신)
# MLFLOW_API=http://mlflow:5000

MLFLOW_EXPERIMENT_NAME=ccrm_experiment



# ========================================================================
# MYSQL ROOT (DB 초기화 전용)
# ========================================================================

MYSQL_ROOT_PASSWORD=your_root_password



# ========================================================================
# MYSQL COMMON
# ========================================================================

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=creditcard_churn_db



# ========================================================================
# MYSQL READER
# ========================================================================

MYSQL_READER_USER=pipeline_select_user
MYSQL_READER_PASSWORD=pipeline_select_pw



# ========================================================================
# MYSQL WRITER
# ========================================================================

MYSQL_WRITER_USER=pipeline_insert_user
MYSQL_WRITER_PASSWORD=pipeline_insert_pw



# ========================================================================
# STREAMLIT
# ========================================================================

# DEV (ngrok)
STREAMLIT_EXTERNAL_URL=https://ccrm-streamlit.ngrok-free.app

# FULL (docker 내부에서 접근)
# STREAMLIT_EXTERNAL_URL=http://streamlit:8501

STREAMLIT_HOST_PORT=18501



# ========================================================================
# DOCKER SERVICE PORT MAPPING (HOST)
# ========================================================================

MYSQL_HOST_PORT=13306
MLFLOW_HOST_PORT=15000
PIPELINE_HOST_PORT=18000
STREAMLIT_HOST_PORT=18501